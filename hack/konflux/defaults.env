# Shared defaults for Konflux setup scripts.
# Override in deploy-local.env (see deploy-local.env.template) for forks or test Quay orgs.

GITHUB_REPO_URL="${GITHUB_REPO_URL:-https://github.com/centos-automotive-suite/automotive-dev-operator}"
GIT_BRANCH="${GIT_BRANCH:-main}"
QUAY_ORG="${QUAY_ORG:-${QUAY_ORGANIZATION:-rh-sdv-cloud}}"
APP_NAME="${APP_NAME:-automotive-dev-operator}"

# Call after sourcing deploy-local.env so overrides take effect.
konflux_apply_image_defaults() {
  QUAY_IMAGE_OPERATOR="${QUAY_IMAGE_OPERATOR:-quay.io/${QUAY_ORG}/${APP_NAME}}"
  QUAY_IMAGE_BUNDLE="${QUAY_IMAGE_BUNDLE:-quay.io/${QUAY_ORG}/${APP_NAME}-bundle}"
  QUAY_IMAGE_CATALOG="${QUAY_IMAGE_CATALOG:-quay.io/${QUAY_ORG}/${APP_NAME}-catalog}"
}
